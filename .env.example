# Backend API URL
NEXT_PUBLIC_API_BASE=http://localhost:4000

# Gemini AI API Key (get from https://aistudio.google.com/app/apikey)
# Free tier: 15 requests per minute, 1500 requests per day
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL for QR code verification links
# Change this when deploying to a different domain
NEXT_PUBLIC_FRONTEND_URL=https://frontend-voter-list.vercel.app
